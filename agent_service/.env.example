# Environment variables for Agent Service
# This is an example file. Copy this to .env and fill in your actual keys.

# 1. LangSmith Configuration
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=Git_AI_Agent

# 2. Aliyun Embedding Configuration
ALIYUN_API_KEY=your_aliyun_api_key_here

# 3. LLM Gateway Configuration
LLM_API_KEY=your_llm_gateway_api_key_here

# 4. Optional Overrides (Uncomment to use)
# SYNC_BATCH_LIMIT=500
# MILVUS_URI=./milvus_demo.db
